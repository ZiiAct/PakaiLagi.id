<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Top row: image + info + delete -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <!-- Image with condition badge overlay -->
            <FrameLayout
                android:layout_width="80dp"
                android:layout_height="80dp">

                <ImageView
                    android:id="@+id/imgWishlistItem"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#E9ECEF"
                    android:src="@android:drawable/ic_menu_gallery"
                    android:scaleType="centerCrop"
                    android:padding="16dp"/>

                <TextView
                    android:id="@+id/tvConditionBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="top|start"
                    android:paddingStart="5dp"
                    android:paddingEnd="5dp"
                    android:paddingTop="2dp"
                    android:paddingBottom="2dp"
                    android:textSize="8sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"/>

            </FrameLayout>

            <!-- Item name + location -->
            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <TextView
                    android:id="@+id/tvWishlistItemName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:textStyle="bold"
                    android:textColor="@color/text_dark"
                    android:textSize="14sp"/>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="6dp">

                    <ImageView
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:src="@android:drawable/ic_menu_mylocation"
                        android:tint="@color/text_grey"/>

                    <TextView
                        android:id="@+id/tvWishlistLocation"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:textSize="11sp"
                        android:textColor="@color/text_grey"
                        android:layout_marginStart="4dp"/>

                </LinearLayout>
            </LinearLayout>

            <!-- Delete button -->
            <ImageButton
                android:id="@+id/btnDeleteWishlist"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@android:drawable/ic_menu_delete"
                android:tint="@color/delete_red"
                android:contentDescription="@string/btn_delete_wishlist"/>

        </LinearLayout>

        <!-- Bottom row: action buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnLihatDetail"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="@string/btn_view_detail"
                android:textSize="12sp"
                android:textColor="@color/primary_green"
                style="@style/Widget.Material3.Button.OutlinedButton"
                app:strokeColor="@color/primary_green"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnAjukan"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:text="@string/btn_apply"
                android:textSize="12sp"
                app:backgroundTint="@color/primary_green"/>

        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
