<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="#FFFFFF"
    app:strokeWidth="0dp"
    tools:ignore="HardcodedText,ContentDescription,SmallSp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp">

        <!-- Gambar Barang + Badge (Kiri) -->
        <FrameLayout
            android:layout_width="90dp"
            android:layout_height="90dp">

            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:cardCornerRadius="8dp"
                app:cardElevation="0dp">

                <ImageView
                    android:id="@+id/imgWishlistItem"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:background="#DDE5DF"
                    android:scaleType="centerCrop" />
            </androidx.cardview.widget.CardView>

            <!-- Badge Kondisi pakai CardView biar bulat sempurna -->
            <androidx.cardview.widget.CardView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="6dp"
                app:cardCornerRadius="6dp"
                app:cardBackgroundColor="#1A7B42"
                app:cardElevation="0dp">

                <TextView
                    android:id="@+id/tvConditionBadge"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="3dp"
                    android:text="LIKE NEW"
                    android:textColor="#FFFFFF"
                    android:textSize="8sp"
                    android:textStyle="bold" />
            </androidx.cardview.widget.CardView>
        </FrameLayout>

        <!-- Info & Tombol (Kanan) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_marginStart="12dp"
            android:orientation="vertical">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <TextView
                    android:id="@+id/tvWishlistItemName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_toStartOf="@+id/btnDeleteWishlist"
                    android:layout_alignParentStart="true"
                    android:text="Judul Barang"
                    android:textColor="#212529"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:maxLines="1"
                    android:ellipsize="end" />

                <ImageButton
                    android:id="@+id/btnDeleteWishlist"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_alignParentEnd="true"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:src="@drawable/bin"
                    app:tint="#D32F2F" />
            </RelativeLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:src="@drawable/location_on"
                    app:tint="#6C757D" />

                <TextView
                    android:id="@+id/tvWishlistLocation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="4dp"
                    android:text="Lokasi Barang"
                    android:textColor="#6C757D"
                    android:textSize="10sp" />
            </LinearLayout>

            <View android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

            <!-- Row Tombol (Pakai CardView biar ramping) -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <androidx.cardview.widget.CardView
                    android:id="@+id/btnLihatDetail"
                    android:layout_width="0dp"
                    android:layout_height="32dp"
                    android:layout_weight="1"
                    app:cardBackgroundColor="#E8F0FE"
                    app:cardCornerRadius="6dp"
                    app:cardElevation="0dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="Lihat Detail"
                        android:textColor="#1A73E8"
                        android:textSize="10sp"
                        android:textStyle="bold" />
                </androidx.cardview.widget.CardView>

                <androidx.cardview.widget.CardView
                    android:id="@+id/btnAjukan"
                    android:layout_width="70dp"
                    android:layout_height="32dp"
                    android:layout_marginStart="8dp"
                    app:cardBackgroundColor="#1A7B42"
                    app:cardCornerRadius="6dp"
                    app:cardElevation="0dp">

                    <TextView
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:gravity="center"
                        android:text="Ajukan"
                        android:textColor="#FFFFFF"
                        android:textSize="10sp"
                        android:textStyle="bold" />
                </androidx.cardview.widget.CardView>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>