<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:background="#FAFAFA"
    tools:ignore="UseCompoundDrawables,SmallSp,Typos,HardcodedText,ContentDescription,SpeakableTextPresentCheck,DisableBaselineAlignment">

    <FrameLayout
        android:id="@+id/fragment_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@id/custom_bottom_nav" />

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_above="@id/custom_bottom_nav"
        android:background="#E5E7EB" />

    <LinearLayout
        android:id="@+id/custom_bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_alignParentBottom="true"
        android:background="#FFFFFF"
        android:elevation="16dp"
        android:orientation="horizontal"
        android:weightSum="5"
        android:gravity="center_vertical"
        android:paddingHorizontal="12dp"
        android:baselineAligned="false">

        <LinearLayout android:id="@+id/nav_home_layout" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:paddingVertical="8dp" android:clickable="true" android:focusable="true">
            <ImageView android:id="@+id/iv_nav_home" android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_nav_home" app:tint="#6C757D" />
            <TextView android:id="@+id/tv_nav_home" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Beranda" android:textColor="#6C757D" android:textSize="10sp" android:layout_marginTop="4dp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/nav_search_layout" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:paddingVertical="8dp" android:clickable="true" android:focusable="true">
            <ImageView android:id="@+id/iv_nav_search" android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_cat_search" app:tint="#6C757D" />
            <TextView android:id="@+id/tv_nav_search" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Cari" android:textColor="#6C757D" android:textSize="10sp" android:layout_marginTop="4dp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/nav_grant_layout" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:paddingVertical="8dp" android:clickable="true" android:focusable="true">
            <ImageView android:id="@+id/iv_nav_grant" android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_nav_add" app:tint="#6C757D" />
            <TextView android:id="@+id/tv_nav_grant" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Hibah" android:textColor="#6C757D" android:textSize="10sp" android:layout_marginTop="4dp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/nav_wishlist_layout" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:paddingVertical="8dp" android:clickable="true" android:focusable="true">
            <ImageView android:id="@+id/iv_nav_wishlist" android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_nav_wishlist" app:tint="#6C757D" />
            <TextView android:id="@+id/tv_nav_wishlist" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Riwayat" android:textColor="#6C757D" android:textSize="10sp" android:layout_marginTop="4dp"/>
        </LinearLayout>

        <LinearLayout android:id="@+id/nav_account_layout" android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical" android:gravity="center" android:paddingVertical="8dp" android:clickable="true" android:focusable="true">
            <ImageView android:id="@+id/iv_nav_account" android:layout_width="24dp" android:layout_height="24dp" android:src="@drawable/ic_nav_profile" app:tint="#6C757D" />
            <TextView android:id="@+id/tv_nav_account" android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Profil" android:textColor="#6C757D" android:textSize="10sp" android:layout_marginTop="4dp"/>
        </LinearLayout>
    </LinearLayout>
</RelativeLayout>