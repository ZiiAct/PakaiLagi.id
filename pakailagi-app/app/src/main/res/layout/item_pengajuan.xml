<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    app:cardBackgroundColor="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Top row: image + content -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <ImageView
                android:id="@+id/imgPengajuanItem"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:background="#E9ECEF"
                android:src="@android:drawable/ic_menu_gallery"
                android:scaleType="centerCrop"
                android:padding="16dp"/>

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical"
                android:layout_marginStart="12dp">

                <!-- Title row + distance badge -->
                <RelativeLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">

                    <TextView
                        android:id="@+id/tvPengajuanName"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_toStartOf="@+id/tvPengajuanDistance"
                        android:layout_alignParentStart="true"
                        android:textStyle="bold"
                        android:textColor="@color/text_dark"
                        android:textSize="13sp"
                        android:maxLines="2"/>

                    <TextView
                        android:id="@+id/tvPengajuanDistance"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_alignParentEnd="true"
                        android:layout_centerVertical="true"
                        android:background="@drawable/bg_distance_badge"
                        android:paddingStart="6dp"
                        android:paddingEnd="6dp"
                        android:paddingTop="2dp"
                        android:paddingBottom="2dp"
                        android:textSize="10sp"
                        android:textColor="@color/text_grey"/>

                </RelativeLayout>

                <!-- Date -->
                <TextView
                    android:id="@+id/tvPengajuanDate"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:textSize="11sp"
                    android:textColor="@color/text_grey"/>

                <!-- Status row -->
                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginTop="6dp">

                    <ImageView
                        android:id="@+id/imgPengajuanStatus"
                        android:layout_width="16dp"
                        android:layout_height="16dp"/>

                    <TextView
                        android:id="@+id/tvPengajuanStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="4dp"
                        android:textSize="12sp"
                        android:textStyle="bold"/>

                </LinearLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- PENDING: Batalkan + Detail buttons -->
        <LinearLayout
            android:id="@+id/layoutPendingButtons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="12dp"
            android:visibility="gone">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnBatalkan"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:layout_marginEnd="6dp"
                android:text="@string/btn_batalkan"
                android:textSize="12sp"
                android:textColor="@color/delete_red"
                style="@style/Widget.Material3.Button.OutlinedButton"
                app:strokeColor="@color/delete_red"/>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnDetailItem"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:layout_marginStart="6dp"
                android:text="@string/btn_detail"
                android:textSize="12sp"
                android:textColor="@color/detail_blue"
                style="@style/Widget.Material3.Button.OutlinedButton"
                app:strokeColor="@color/detail_blue"/>

        </LinearLayout>

        <!-- READY: location card + Kabari button -->
        <LinearLayout
            android:id="@+id/layoutReadyContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="12dp"
            android:visibility="gone">

            <!-- Location card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_location_card"
                android:padding="12dp"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/lokasi_pengambilan"
                        android:textSize="12sp"
                        android:textStyle="bold"
                        android:textColor="@color/primary_green"/>

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical"
                        android:layout_marginTop="4dp">

                        <ImageView
                            android:layout_width="12dp"
                            android:layout_height="12dp"
                            android:src="@android:drawable/ic_menu_mylocation"
                            android:tint="@color/primary_green"/>

                        <TextView
                            android:id="@+id/tvPickupAddress"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="4dp"
                            android:textSize="11sp"
                            android:textColor="@color/text_dark"/>

                    </LinearLayout>
                </LinearLayout>

                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@android:drawable/ic_menu_compass"
                    android:tint="@color/primary_green"/>

            </LinearLayout>

            <!-- Kabari button -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnKabari"
                android:layout_width="match_parent"
                android:layout_height="48dp"
                android:layout_marginTop="8dp"
                android:text="@string/btn_kabari"
                android:textSize="14sp"
                app:backgroundTint="@color/primary_green"
                app:cornerRadius="8dp"/>

        </LinearLayout>

    </LinearLayout>
</com.google.android.material.card.MaterialCardView>
