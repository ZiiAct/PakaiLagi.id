<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_light_grey"
    tools:ignore="HardcodedText,ContentDescription,SpeakableTextPresentCheck">

    <LinearLayout
        android:id="@+id/cariHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/cari_header"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingTop="12dp"
        android:paddingBottom="14dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="12dp">

            <ImageButton
                android:id="@+id/btnCariBack"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:src="@drawable/ic_arrow_back"
                android:contentDescription="Kembali"/>

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:text="@string/cari_barang_title"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:orientation="horizontal"
            android:background="@drawable/bg_search_bar"
            android:gravity="center_vertical"
            android:paddingStart="14dp"
            android:paddingEnd="14dp">

            <ImageView
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:src="@android:drawable/ic_menu_search"
                app:tint="#9E9E9E"
                android:contentDescription="Cari"/>

            <EditText
                android:id="@+id/etCariSearch"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="8dp"
                android:background="@null"
                android:hint="@string/cari_barang_hint"
                android:textSize="14sp"
                android:textColorHint="#AAAAAA"
                android:singleLine="true"
                android:imeOptions="actionSearch"
                android:inputType="text"/>
        </LinearLayout>

        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:layout_marginTop="12dp">

            <com.google.android.material.chip.ChipGroup
                android:id="@+id/chipGroupCariFilter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:singleSelection="true"
                app:selectionRequired="true">

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipCariSemua"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="@string/cari_filter_all"
                    android:checked="true"
                    android:textColor="@color/chip_cari_text_color"
                    app:chipBackgroundColor="@color/chip_cari_bg_color"
                    app:chipStrokeColor="@color/chip_cari_stroke_color"
                    app:chipStrokeWidth="1.5dp"
                    app:chipIconVisible="false"
                    app:checkedIconVisible="false"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipCariElektronik"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="@string/cari_filter_elektronik"
                    android:textColor="@color/chip_cari_text_color"
                    app:chipBackgroundColor="@color/chip_cari_bg_color"
                    app:chipStrokeColor="@color/chip_cari_stroke_color"
                    app:chipStrokeWidth="1.5dp"
                    app:chipIconVisible="false"
                    app:checkedIconVisible="false"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipCariPerabot"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="@string/cari_filter_perabot"
                    android:textColor="@color/chip_cari_text_color"
                    app:chipBackgroundColor="@color/chip_cari_bg_color"
                    app:chipStrokeColor="@color/chip_cari_stroke_color"
                    app:chipStrokeWidth="1.5dp"
                    app:chipIconVisible="false"
                    app:checkedIconVisible="false"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipCariOlahraga"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="@string/cari_filter_olahraga"
                    android:textColor="@color/chip_cari_text_color"
                    app:chipBackgroundColor="@color/chip_cari_bg_color"
                    app:chipStrokeColor="@color/chip_cari_stroke_color"
                    app:chipStrokeWidth="1.5dp"
                    app:chipIconVisible="false"
                    app:checkedIconVisible="false"/>

                <com.google.android.material.chip.Chip
                    android:id="@+id/chipCariBuku"
                    style="@style/Widget.Material3.Chip.Filter"
                    android:layout_width="wrap_content"
                    android:layout_height="36dp"
                    android:text="@string/cari_filter_buku"
                    android:textColor="@color/chip_cari_text_color"
                    app:chipBackgroundColor="@color/chip_cari_bg_color"
                    app:chipStrokeColor="@color/chip_cari_stroke_color"
                    app:chipStrokeWidth="1.5dp"
                    app:chipIconVisible="false"
                    app:checkedIconVisible="false"/>
            </com.google.android.material.chip.ChipGroup>
        </HorizontalScrollView>
    </LinearLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerCariBarang"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="8dp"
        android:clipToPadding="false"
        app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
        app:spanCount="2"
        tools:listitem="@layout/item_cari_barang" />

</LinearLayout>