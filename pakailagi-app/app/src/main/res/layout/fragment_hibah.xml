<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF"
    android:fillViewport="true"
    android:scrollbars="none"
    tools:ignore="UseCompoundDrawables,SmallSp,Typos,HardcodedText,ContentDescription,SpeakableTextPresentCheck,Autofill">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingHorizontal="20dp"
        android:paddingTop="24dp"
        android:paddingBottom="40dp">

        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:text="Hibahkan Barang"
                android:textColor="#1A7B42"
                android:textSize="20sp"
                android:textStyle="bold" />

            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:src="@drawable/ic_info_green" />
        </RelativeLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:background="@drawable/bg_step_active"
                    android:gravity="center"
                    android:text="1"
                    android:textColor="#FFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Info Barang"
                    android:textColor="#1A7B42"
                    android:textSize="10sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <View
                android:layout_width="0dp"
                android:layout_height="2dp"
                android:layout_weight="1"
                android:layout_marginBottom="14dp"
                android:background="#DDE5DF" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:background="@drawable/bg_step_inactive"
                    android:gravity="center"
                    android:text="2"
                    android:textColor="#A0AAB5"
                    android:textSize="12sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Lokasi"
                    android:textColor="#A0AAB5"
                    android:textSize="10sp" />
            </LinearLayout>

            <View
                android:layout_width="0dp"
                android:layout_height="2dp"
                android:layout_weight="1"
                android:layout_marginBottom="14dp"
                android:background="#DDE5DF" />

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center">
                <TextView
                    android:layout_width="28dp"
                    android:layout_height="28dp"
                    android:background="@drawable/bg_step_inactive"
                    android:gravity="center"
                    android:text="3"
                    android:textColor="#A0AAB5"
                    android:textSize="12sp"
                    android:textStyle="bold" />
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:text="Selesai"
                    android:textColor="#A0AAB5"
                    android:textSize="10sp" />
            </LinearLayout>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F4F8" android:layout_marginTop="24dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Foto Barang"
            android:textColor="#212529"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Unggah foto yang jelas untuk mempermudah calon penerima."
            android:textColor="#6C757D"
            android:textSize="11sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">

            <LinearLayout
            android:id="@+id/boxUtama"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:background="@drawable/bg_upload_dashed_green"
            android:gravity="center"
            android:orientation="vertical">
            <ImageView
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:src="@drawable/ic_camera_add_green" />
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                android:text="Utama"
                android:textColor="#1A7B42"
                android:textSize="10sp"
                android:textStyle="bold"/>
        </LinearLayout>

        <androidx.cardview.widget.CardView
            android:id="@+id/cardPreviewImage"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:layout_marginStart="12dp"
            android:visibility="gone"
            app:cardCornerRadius="12dp"
            app:cardElevation="0dp">
            <ImageView
                android:id="@+id/ivImage"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop" />
            </androidx.cardview.widget.CardView>

            <LinearLayout
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:layout_marginStart="12dp"
                android:background="@drawable/bg_upload_dashed_grey"
                android:gravity="center"
                android:orientation="vertical">
                <ImageView
                    android:layout_width="24dp"
                    android:layout_height="24dp"
                    android:src="@drawable/ic_gallery_grey" />
            </LinearLayout>
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F4F8" android:layout_marginTop="24dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Detail Barang"
            android:textColor="#212529"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Nama Barang"
            android:textColor="#495057"
            android:textSize="10sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etNamaBarang"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_input_outline"
            android:hint="Contoh: Buku Kalkulus semester 1"
            android:textColorHint="#A0AAB5"
            android:paddingHorizontal="16dp"
            android:textColor="#212529"
            android:textSize="12sp"
            android:inputType="text"
            android:importantForAutofill="no" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Kategori"
            android:textColor="#495057"
            android:textSize="10sp"
            android:textStyle="bold" />

        <RelativeLayout
            android:id="@+id/layoutKategori"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_input_outline"
            android:paddingHorizontal="16dp">

            <TextView
                android:id="@+id/tvKategori"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerVertical="true"
                android:text="Pilih Kategori"
                android:textColor="#212529"
                android:textSize="12sp" />

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_alignParentEnd="true"
                android:layout_centerVertical="true"
                android:src="@android:drawable/arrow_down_float"
                app:tint="#6C757D" />
        </RelativeLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Kondisi Barang"
            android:textColor="#495057"
            android:textSize="10sp"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/chipGood"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_chip_green_solid"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:text="Good"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/chipFair"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_chip_outline_grey"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:text="Fair"
                android:textColor="#6C757D"
                android:textSize="11sp" />

            <TextView
                android:id="@+id/chipPoor"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_chip_outline_grey"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:text="Poor"
                android:textColor="#6C757D"
                android:textSize="11sp" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Deskripsi Barang"
            android:textColor="#495057"
            android:textSize="10sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etDeskripsiBarang"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_input_outline"
            android:gravity="top|start"
            android:hint="Ceritakan sedikit tentang kondisi barang Anda..."
            android:textColorHint="#A0AAB5"
            android:padding="16dp"
            android:textColor="#212529"
            android:textSize="12sp"
            android:inputType="textMultiLine"
            android:importantForAutofill="no" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Nomor Kontak"
            android:textColor="#495057"
            android:textSize="10sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etKontakHibah"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_input_outline"
            android:hint="Contoh: 08123456789"
            android:textColorHint="#A0AAB5"
            android:paddingHorizontal="16dp"
            android:textColor="#212529"
            android:textSize="12sp"
            android:inputType="phone"
            android:importantForAutofill="no" />

        <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#F0F4F8" android:layout_marginTop="24dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Instruksi Pengambilan"
            android:textColor="#212529"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:text="Tentukan bagaimana cara calon penerima mengambil barang ini."
            android:textColor="#6C757D"
            android:textSize="11sp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/chipPickup"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_chip_green_solid"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:text="Pick Up Langsung"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/chipCOD"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_chip_outline_grey"
                android:paddingHorizontal="16dp"
                android:paddingVertical="8dp"
                android:text="Ketemuan (COD)"
                android:textColor="#6C757D"
                android:textSize="11sp" />
        </LinearLayout>

        <TextView
            android:id="@+id/chipKurir"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_chip_outline_grey"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            android:text="Kirim via Kurir"
            android:textColor="#6C757D"
            android:textSize="11sp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="Detail Lokasi/Waktu"
            android:textColor="#495057"
            android:textSize="10sp"
            android:textStyle="bold" />

        <EditText
            android:id="@+id/etLokasiWaktu"
            android:layout_width="match_parent"
            android:layout_height="80dp"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_input_outline"
            android:gravity="top|start"
            android:hint="Contoh: Ambil di lobby Kost Pelangi jam 5 sore"
            android:textColorHint="#A0AAB5"
            android:padding="16dp"
            android:textColor="#212529"
            android:textSize="12sp"
            android:inputType="textMultiLine"
            android:importantForAutofill="no" />

        <View android:layout_width="match_parent" android:layout_height="24dp" />

        <androidx.cardview.widget.CardView
            android:id="@+id/btnSubmitHibah"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            app:cardBackgroundColor="#1A7B42"
            app:cardCornerRadius="8dp"
            app:cardElevation="0dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:orientation="horizontal">

                <ImageView
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:src="@drawable/ic_logo_utama" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="8dp"
                    android:text="Hibahkan Sekarang"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:text="Dengan menghibahkan, Anda setuju dengan\nKetentuan Komunitas kami."
            android:textColor="#6C757D"
            android:textSize="10sp"
            android:lineSpacingExtra="4dp" />

    </LinearLayout>
</ScrollView>